<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Style Selector="TextBox">
        <Setter Property="Background" Value="#FFFFFF"/>
        <Setter Property="Foreground" Value="{DynamicResource ResourceKey=TextColour}"/>
        <Setter Property="BorderBrush" Value="#ADADAD"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="0"/>
        <Setter Property="MinHeight" Value="24"/>
        <Setter Property="Padding" Value="6,0"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="SelectionBrush" Value="#CCE4F7"/>
        <Setter Property="CaretBrush" Value="#005A9E"/>
    </Style>

    <Style Selector="TextBox /template/ Border">
        <Setter Property="CornerRadius" Value="0"/>
    </Style>

    <Style Selector="TextBox:pointerover">
        <Setter Property="BorderBrush" Value="#0078D7"/>
    </Style>

    <Style Selector="TextBox:focus">
        <Setter Property="BorderBrush" Value="#0078D7"/>
    </Style>

    <Style Selector="TextBox:focus /template/ Border">
        <Setter Property="BorderBrush" Value="#0078D7"/>
    </Style>

    <Style Selector="TextBox:disabled">
        <Setter Property="Background" Value="#F3F3F3"/>
        <Setter Property="Foreground" Value="#838383"/>
        <Setter Property="BorderBrush" Value="#D0D0D0"/>
    </Style>

    <Style Selector="TextBox.monospace-input">
        <Setter Property="FontFamily" Value="Consolas"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Padding" Value="4,0"/>
        <Setter Property="MinHeight" Value="22"/>
    </Style>

</Styles>
