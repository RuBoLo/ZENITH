<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Window Buttons -->
    <Style Selector="Button.window-btn">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Foreground" Value="{DynamicResource ResourceKey=TextColour}"/>

        <Setter Property="VerticalAlignment" Value="Stretch"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>

        <Setter Property="Width" Value="46"/>
    </Style>
    <Style Selector="Button.window-btn /template/ ContentPresenter">
        <Setter Property="CornerRadius" Value="0"/>
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="Background" Duration="0:0:0.1" Easing="LinearEasing"/>
            </Transitions>
        </Setter>
    </Style>
    <Style Selector="Button.window-btn:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource ResourceKey=WindowButtonHoverColour}"/>
    </Style>
    <Style Selector="Button.window-btn:pressed">
		<Setter Property="RenderTransform" Value="none"/>
    </Style>
    <Style Selector="Button.window-btn:pressed /template/ ContentPresenter">
		<Setter Property="Background" Value="{DynamicResource ResourceKey=WindowButtonPressedColour}"/>
    </Style>
    <Style Selector="Button.window-btn.exit:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource ResourceKey=ExitButtonHoverColour}"/>
    </Style>
    <Style Selector="Button.window-btn.exit:pressed /template/ ContentPresenter">
		<Setter Property="Background" Value="{DynamicResource ResourceKey=ExitButtonPressedColour}"/>
    </Style>
    <!-- Breadcrumb Segment Button -->
    <Style Selector="Button.crumb">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource ResourceKey=TextColour}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="6,3"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Cursor" Value="Hand"/>
    </Style>
    <Style Selector="Button.crumb:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundBaseLowBrush}"/>
    </Style>

<!-- Windows 10 style control button -->
<Style Selector="Button.control-btn">
    <Setter Property="Background" Value="#E3E3E3"/>
    <Setter Property="Foreground" Value="#1A1A1A"/>
    <Setter Property="BorderBrush" Value="#ADADAD"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="Padding" Value="8,1"/>
    <Setter Property="FontSize" Value="11"/>
    <Setter Property="MinHeight" Value="20"/>
    <Setter Property="Height" Value="20"/>
    <Setter Property="RenderTransform" Value="none"/>
    <Setter Property="HorizontalContentAlignment" Value="Center"/>
    <Setter Property="VerticalContentAlignment" Value="Center"/>
</Style>

<Style Selector="Button.control-btn /template/ ContentPresenter">
    <Setter Property="CornerRadius" Value="0"/>
</Style>

<Style Selector="Button.control-btn:pointerover">
    <Setter Property="Background" Value="#E5F1FB"/>
    <Setter Property="BorderBrush" Value="#0078D7"/>
</Style>

<Style Selector="Button.control-btn:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="#E5F1FB"/>
    <Setter Property="BorderBrush" Value="#0078D7"/>
</Style>

<Style Selector="Button.control-btn:pressed">
    <Setter Property="Background" Value="#CCE4F7"/>
    <Setter Property="BorderBrush" Value="#005A9E"/>
    <Setter Property="RenderTransform" Value="none"/>
</Style>

<Style Selector="Button.control-btn:pressed /template/ ContentPresenter">
    <Setter Property="Background" Value="#CCE4F7"/>
    <Setter Property="BorderBrush" Value="#005A9E"/>
</Style>

<Style Selector="Button.control-btn:disabled">
    <Setter Property="Background" Value="#F3F3F3"/>
    <Setter Property="Foreground" Value="#838383"/>
    <Setter Property="BorderBrush" Value="#D0D0D0"/>
</Style>

<Style Selector="Button.control-btn:disabled /template/ ContentPresenter">
    <Setter Property="Background" Value="#F3F3F3"/>
    <Setter Property="BorderBrush" Value="#D0D0D0"/>
</Style>



<Style Selector="Border.drag-bar">
    <Setter Property="Background" Value="Transparent"/>
</Style>

<Style Selector="Border.drag-hatch">
    <Setter Property="Width" Value="60"/>
    <Setter Property="Height" Value="18"/>
    <Setter Property="Margin" Value="8,0"/>
    <Setter Property="HorizontalAlignment" Value="Center"/>
    <Setter Property="VerticalAlignment" Value="Center"/>
    <Setter Property="IsHitTestVisible" Value="False"/>
    <Setter Property="Background">
        <VisualBrush TileMode="Tile"
                     Stretch="None"
                     DestinationRect="0,0,6,6">
            <VisualBrush.Visual>
                <Canvas Width="6"
                        Height="6"
                        Background="Transparent">
                    <Line StartPoint="1,5"
                          EndPoint="5,1"
                          Stroke="#55000000"
                          StrokeThickness="1"/>
                </Canvas>
            </VisualBrush.Visual>
        </VisualBrush>
    </Setter>
</Style>


</Styles>
