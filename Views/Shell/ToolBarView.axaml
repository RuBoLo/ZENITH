<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ZENITH.ViewModels.Shell"
             xmlns:svg="clr-namespace:Avalonia.Svg.Skia;assembly=Svg.Controls.Skia.Avalonia"
             x:DataType="vm:ToolBarViewModel"

             x:Class="ZENITH.Views.Shell.ToolBarView">

    <Border Background="{DynamicResource WindowColour}">

        <StackPanel Orientation="Horizontal"
                    VerticalAlignment="Center"
                    Spacing="4"
                    Margin="6,0">

            <Button Content="-"
                    Command="{Binding ZoomOutCommand}"
                    Width="18"
                    Height="18"
                    Padding="0"/>

            <Button Command="{Binding ZoomInCommand}"
                    Width="18"
                    Height="18"
                    Padding="0">
                <svg:Svg Path="/Assets/ButtonIcons/drawing.svg"
                         Width="14"
                         Height="14"/>
            </Button>

            <ComboBox ItemsSource="{Binding ChannelViewOptions}"
                      SelectedItem="{Binding SelectedChannelViewOption, Mode=TwoWay}"
                      IsEnabled="{Binding HasDocumentSelected}"
                      Width="120">

                <ComboBox.ItemTemplate>

                    <DataTemplate x:DataType="vm:ImageChannelViewOption">

                        <TextBlock Text="{Binding Label}"/>

                    </DataTemplate>

                </ComboBox.ItemTemplate>

            </ComboBox>

        </StackPanel>

    </Border>

</UserControl>
