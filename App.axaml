<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ZENITH.ViewModels.Shell"
             xmlns:documentVm="using:ZENITH.ViewModels.Documents"
             xmlns:operatorVm="using:ZENITH.ViewModels.Operators"
             xmlns:consoleServices="using:ZENITH.Services.Console"
             xmlns:views="using:ZENITH.Views.Shell"
             xmlns:documentViews="using:ZENITH.Views.Documents"
             xmlns:operatorViews="using:ZENITH.Views.Operators"
             x:Class="ZENITH.App"
             RequestedThemeVariant="Light">
    
    <Application.DataTemplates>
        <DataTemplate DataType="vm:ToolBarViewModel">
            <views:ToolBarView />
        </DataTemplate>
        <DataTemplate DataType="vm:WorkspaceViewModel">
            <views:WorkspaceView />
        </DataTemplate>
        <DataTemplate DataType="vm:BottomBarViewModel">
            <views:BottomBarView />
        </DataTemplate>
        <DataTemplate DataType="consoleServices:ConsoleService">
            <views:ConsoleView />
        </DataTemplate>

        <DataTemplate DataType="documentVm:ImageDocumentViewModel">
            <documentViews:ImageDocumentView />
        </DataTemplate>
        <DataTemplate DataType="operatorVm:IntegrationWindowViewModel">
            <operatorViews:IntegrationWindowView />
        </DataTemplate>
    </Application.DataTemplates>

    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="/Styles/ButtonStyles.axaml"/>
        <StyleInclude Source="/Styles/TextBoxStyles.axaml"/>
        <StyleInclude Source="/Styles/ConsoleStyles.axaml"/>
        <StyleInclude Source="/Styles/ComboBoxStyles.axaml"/>
        <StyleInclude Source="/Styles/MenuStyles.axaml"/>
        <StyleInclude Source="/Styles/RadioButtonStyles.axaml"/>
        <StyleInclude Source="/Styles/ProgressBarStyles.axaml"/>
        <StyleInclude Source="/Styles/ScrollBarStyles.axaml"/>
        <StyleInclude Source="/Styles/ToolTipStyles.axaml"/>
    </Application.Styles>

    <Application.Resources>

		<SolidColorBrush x:Key="WindowColour" Color="#F5F5F5"/>
        <SolidColorBrush x:Key="BarColour" Color="#EDEDED"/>
        <SolidColorBrush x:Key="BorderColour" Color="#424242"/>
        <SolidColorBrush x:Key="ImageBorderColour" Color="#CCCCCC"/>
        <SolidColorBrush x:Key="ImageSelectedBorderColour" Color="#0078D7"/>
        <SolidColorBrush x:Key="TextColour" Color="#000000"/>
        <SolidColorBrush x:Key="ConsoleBackground" Color="#090909"/>

        <SolidColorBrush x:Key="WindowButtonHoverColour" Color="#7F7F7F"/>
        <SolidColorBrush x:Key="WindowButtonPressedColour" Color="#C8C8C8"/>
        <SolidColorBrush x:Key="ExitButtonHoverColour" Color="#E81123"/>
        <SolidColorBrush x:Key="ExitButtonPressedColour" Color="#C50F1F"/>

        <SolidColorBrush x:Key="ParentMenuHoverColour" Color="#DDDDDD"/>

    </Application.Resources>
</Application>
